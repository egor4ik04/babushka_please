        \u0434\u0438\u0441\u043F\u0435\u043F\u0441\u0438\u044F"
      IsRight: 0
    - Id: 4
      Name: "\u0420\u0430\u043A \u0436\u0435\u043B\u0443\u0434\u043A\u0430"
