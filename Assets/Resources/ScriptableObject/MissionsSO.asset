      Name: "\u041E\u0440\u0433\u0430\u043D\u0438\u0437\u043C \u0432 \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u043D\u043E\u0439
        \u0444\u0430\u0437\u0435"
      IsRight: 0
    VerdictList:
    - Id: 0
