      DiseaseId: 0
  - Id: 1
    ProblemText: "- \u0414\u043E\u043A\u0442\u043E\u0440 <link=\"1\">\u043A\u0430\u0448\u0435\u043B\u044C
      \u0441 \u043C\u043E\u043A\u0440\u043E\u0442\u043E\u0439</link> \u043C\u0435\u043D\u044F
      \u0441\u043E\u0432\u0441\u0435\u043C \u0437\u0430\u043C\u0443\u0447\u0438\u043B.
      \u041D\u0430\u0432\u0435\u0440\u043D\u043E\u0435, \u043E\u0442 \u0442\u043E\u0433\u043E,
      \u0447\u0442\u043E \u043A\u0443\u0440\u044E \u043C\u043D\u043E\u0433\u043E,
      \u043F\u043E \u043F\u0430\u0447\u043A\u0435 \u0432 \u0434\u0435\u043D\u044C,
      37 \u043B\u0435\u0442 \u0443\u0436\u0435 \u043A\u0430\u043A.\r\n- \u041A\u0430\u0448\u043B\u044F\u044E
      \u0447\u0430\u0449\u0435 \u0432\u0441\u0435\u0433\u043E \u043F\u043E \u0443\u0442\u0440\u0430\u043C.
      <link=\"2\">\u0422\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u0430
      \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0434\u043D\u0435\u0439
      \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F</link> \u043F\u043E \u0446\u0435\u043B\u044B\u0445
      37-38 \u0433\u0440\u0430\u0434\u0443\u0441\u043E\u0432. \r\n- \u0413\u043E\u0434\u0430
      \u0434\u0432\u0430 \u2013 \u0442\u0440\u0438 \u043D\u0430\u0437\u0430\u0434
      \u043F\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C \u0443 \u043C\u0435\u043D\u044F
      <link=\"3\">\u043D\u0430 \u0433\u043E\u043B\u0435\u043D\u044F\u0445 \u043E\u0442\u0442\u0451\u043A\u0438</link>,
      \u0440\u043E\u0432\u043D\u043E \u0442\u043E\u0433\u0434\u0430 \u0438 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
      <link=\"4\">\u043E\u0442\u0434\u044B\u0448\u043A\u0430 \u043F\u043E\u0447\u0442\u0438
      \u043E\u0442 \u0432\u0441\u0435\u0433\u043E</link>, \u0434\u0430\u0436\u0435
      \u043A\u043E\u0433\u0434\u0430 \u043F\u043E \u043B\u0435\u0441\u0442\u043D\u0438\u0446\u0435
      \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u044E\u0441\u044C. \u0421 \u0442\u0435\u0445
      \u043F\u043E\u0440 \u0447\u0430\u0441\u0442\u043E \u0432\u043E\u0442 <link=\"5\">\u0441\u043B\u0430\u0431\u043E\u0441\u0442\u044C</link>
      \u0432\u043E\u0442 \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F.\r\n-
      \u0412 \u043F\u0440\u043E\u0448\u043B\u043E\u043C \u0433\u043E\u0434\u0443
      \u043E\u0434\u0438\u043D \u0440\u0430\u0437 \u0431\u044B\u043B \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D
      \u0431\u044B\u043B \u044F \u0432 \u0441\u0442\u0430\u0446\u0438\u043E\u043D\u0430\u0440,
      \u0441\u043A\u0430\u0437\u0430\u043B\u0438 - <link=\"6\">\u043E\u0431\u043E\u0441\u0442\u0440\u0435\u043D\u0438\u0435</link>. 
      \r\n"
    PossibleDiseases:
    - Id: 0
      Name: "\u0425\u0440\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u043E\u0431\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u0430\u044F
        \u0431\u043E\u043B\u0435\u0437\u043D\u044C \u043B\u0435\u0433\u043A\u0438\u0445 "
      IsRight: 1
    - Id: 1
      Name: "\u043E\u0436\u0438\u0440\u0435\u043D\u0438\u0435 \u0441 \u0433\u0438\u043F\u043E\u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u0435\u0439"
      IsRight: 0
